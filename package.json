{
  "name": "abiplaner",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "db:create": "wrangler d1 create abiplaner-db",
    "db:schema": "wrangler d1 execute abiplaner-db --local --file=./schema.sql",
    "db:seed": "wrangler d1 execute abiplaner-db --local --file=./seed.sql",
    "db:schema:prod": "wrangler d1 execute abiplaner-db --remote --file=./schema.sql",
    "db:seed:prod": "wrangler d1 execute abiplaner-db --remote --file=./seed.sql",
    "pages:dev": "wrangler pages dev dist --d1=DB=abiplaner-db",
    "deploy": "npm run build && wrangler pages deploy dist"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.0",
    "wrangler": "^3.99.0"
  }
}
